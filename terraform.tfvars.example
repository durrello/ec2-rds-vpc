# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Prefer exporting TF_VAR_db_password instead of putting the password in a file.

environment   = "dev"
instance_name = "demo-public-ec2"
instance_type = "t3.micro"
ami_id        = "ami-0xxxxxxxxxxxxxxxx" # valid AMI in your region

vpc_name           = "demo-vpc"
vpc_cidr           = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]

# RDS
db_name              = "demoappdb"
db_allocated_storage = 20
db_instance_class    = "db.t3.micro"
db_username          = "admin"
# Pass db_password via TF_VAR_db_password (do not store it here)
